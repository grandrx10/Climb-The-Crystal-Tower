  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 726074242}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8503e2c6600efd74389ba0e1a2592a8a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TwoCT.FreeRoam.Interactable
  ShowTopMostFoldoutHeaderGroup: 1
  lines:
  - speaker: Leafy
    text: Hey! Hey you! Yeah you, the lady with the orange hair! Can you help me
      out?
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Fiore
    text: M-me?
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Leafy
    text: Yeah! As you can see, I'm stuck in a cage.
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Fiore
    text: Uhm. Okay...
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Leafy
    text: You might be wondering, why am I stuck in a cage?
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Fiore
    text: No... not really.
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Leafy
    text: Well you see, I was walking about at the foot of the great Crystal Tower,
      when I saw a piece of cheese underneath a giant metal cage hanging by a thin
      piece of rope.
    autoAdvanceSeconds: 4
    actions: []
  - speaker: Leafy
    text: Just when I had picked up the cheese, WHAM! The cage fell on me!
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Fiore
    text: Uhm... Okay...
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Leafy
    text: So, do you think you could help me out here? That bar on my right seems
      a little weak, maybe if you give it a good kick, it'll break apart!
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Fiore
    text: That doesn't seem very safe...
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Leafy
    text: Pretty please? You wouldn't leave a girl trapped in here all by her lonesome,
      would you?
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Fiore
    text: Okay. Okay! I'll do it...
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: 
    text: With a hesitant kick, the cage bar breaks apart!
    autoAdvanceSeconds: 2.5
    actions:
    - rid: 7301862582123495532
    - rid: 7301862602788044882
    - rid: 7301862602788044883
  - speaker: Fiore
    text: Ow....
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Leafy
    text: Thanks! I sprained my ankle from eating the cheese, so I couldn't do it
      myself. The name's Leafy, nice to meet you!
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Fiore
    text: I'm Fiore...
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Leafy
    text: You're here for the Crystal Tower too, aren't you? We can climb it together!
      Follow me!
    autoAdvanceSeconds: 2.5
    actions: []
  - speaker: Fiore
    text: Okay.
    autoAdvanceSeconds: 2.5
    actions: []
  requiresAllPlayers: 0
  interactRadius: 1.75
  allowedInitiators:
  - {fileID: 11400000, guid: a26779a96b4d1aa478360802dfc7c646, type: 2}
  - {fileID: 11400000, guid: f85c3e355aa72db479eae1d223563e4f, type: 2}
  triggersCombat: 0
  combatScene: Combat
  oneTimeOnly: 0
  references:
